{
  "info": {
    "name": "Biblioteca API",
    "description": "Collection para testar a API FastAPI de biblioteca com usuarios, login JWT, livros, generos e enderecos. Use apenas dados ficticios e nao salve tokens ou credenciais reais nesta collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "test_username",
      "value": "usuario.exemplo"
    },
    {
      "key": "test_password",
      "value": "<senha-forte>"
    },
    {
      "key": "test_email",
      "value": "usuario.exemplo@dominio.local"
    },
    {
      "key": "usuario_id",
      "value": "1"
    },
    {
      "key": "livro_id",
      "value": "1"
    },
    {
      "key": "endereco_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Cadastrar usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Usuario Exemplo\",\n  \"username\": \"{{test_username}}\",\n  \"email\": \"{{test_email}}\",\n  \"senha\": \"{{test_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/usuarios",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "usuarios"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{test_username}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{test_password}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/usuarios/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "usuarios",
                "login"
              ]
            }
          }
        },
        {
          "name": "Listar usuarios",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/usuarios",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "usuarios"
              ]
            }
          }
        },
        {
          "name": "Buscar usuario por ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/usuarios/{{usuario_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "usuarios",
                "{{usuario_id}}"
              ]
            }
          }
        },
        {
          "name": "Atualizar usuario",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Usuario Exemplo Atualizado\",\n  \"username\": \"{{test_username}}\",\n  \"email\": \"{{test_email}}\",\n  \"senha\": \"{{test_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/usuarios/{{usuario_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "usuarios",
                "{{usuario_id}}"
              ]
            }
          }
        },
        {
          "name": "Deletar usuario",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/usuarios/{{usuario_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "usuarios",
                "{{usuario_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Livros e generos",
      "item": [
        {
          "name": "Verificar genero disponivel",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/livros/generos/disponiveis/romance",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "livros",
                "generos",
                "disponiveis",
                "romance"
              ]
            }
          }
        },
        {
          "name": "Adicionar genero",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"genero\": \"fantasia\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/livros/generos",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "livros",
                "generos"
              ]
            }
          }
        },
        {
          "name": "Cadastrar livro",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"fantasia\",\n  \"data_publicacao\": \"2024-01-10\",\n  \"preco\": 49.9\n}"
            },
            "url": {
              "raw": "{{base_url}}/livros",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "livros"
              ]
            }
          }
        },
        {
          "name": "Listar livros",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/livros",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "livros"
              ]
            }
          }
        },
        {
          "name": "Buscar livro por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/livros/{{livro_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "livros",
                "{{livro_id}}"
              ]
            }
          }
        },
        {
          "name": "Atualizar livro",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"fantasia\",\n  \"data_publicacao\": \"2024-01-10\",\n  \"preco\": 59.9\n}"
            },
            "url": {
              "raw": "{{base_url}}/livros/{{livro_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "livros",
                "{{livro_id}}"
              ]
            }
          }
        },
        {
          "name": "Deletar livro",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/livros/{{livro_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "livros",
                "{{livro_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Enderecos",
      "item": [
        {
          "name": "Cadastrar endereco",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"logradouro\": \"Rua Exemplo\",\n  \"numero\": 100,\n  \"bairro\": \"Bairro Exemplo\",\n  \"cidade\": \"Cidade Exemplo\",\n  \"estado\": \"SP\",\n  \"cep\": \"00000000\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/enderecos",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "enderecos"
              ]
            }
          }
        },
        {
          "name": "Listar enderecos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/enderecos",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "enderecos"
              ]
            }
          }
        },
        {
          "name": "Buscar endereco por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/enderecos/{{endereco_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "enderecos",
                "{{endereco_id}}"
              ]
            }

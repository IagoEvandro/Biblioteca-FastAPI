        },
        {
          "name": "Atualizar endereco",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"logradouro\": \"Rua Exemplo Atualizada\",\n  \"numero\": 200,\n  \"bairro\": \"Bairro Exemplo\",\n  \"cidade\": \"Cidade Exemplo\",\n  \"estado\": \"SP\",\n  \"cep\": \"00000000\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/enderecos/{{endereco_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "enderecos",
                "{{endereco_id}}"
              ]
            }
          }
        },
        {
          "name": "Deletar endereco",
          "request": {
            "auth": {

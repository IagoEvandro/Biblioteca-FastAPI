              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/enderecos/{{endereco_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "enderecos",
                "{{endereco_id}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
